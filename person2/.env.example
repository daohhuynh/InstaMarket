# Required for AWS Bedrock Nova Lite
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Optional integrations for Person 1 / Person 4 handoff
CLOB_ENDPOINT=http://localhost:8080/api/paper-trades
MARKET_STATE_ENDPOINT=http://localhost:8080/api/markets
TWITTER_COMMENTS_ENDPOINT=http://localhost:9000/comments
APIFY_API_TOKEN=
YOUTUBE_API_KEY=
APIFY_GOOGLE_ACTOR_IDS=apify/google-search-scraper
APIFY_X_ACTOR_IDS=apidojo/twitter-scraper-lite,apidojo/tweet-scraper,scrapier/twitter-x-tweets-scraper
APIFY_TIKTOK_ACTOR_ID=clockworks/tiktok-comments-scraper
APIFY_REDDIT_ACTOR_ID=trudax/reddit-scraper-lite
SCRAPER_DISABLE_APIFY=false
LAVA_API_KEY=
LAVA_X_ENDPOINT=https://api.lava.so/v1/x/search
SCRAPER_MAX_ITEMS_PER_SOURCE=6
SCRAPER_HTTP_TIMEOUT_SECONDS=30
SCRAPER_HTTP_RETRIES=2
# Default is direct networking (proxy bypass) to avoid local proxy misconfig.
# Set true only if your environment requires a corporate/system proxy.
SCRAPER_USE_SYSTEM_PROXY=false

# Simulation tuning
SIM_COMMENT_LIMIT=30
SIM_MIN_ORDER_USDC=1
SIM_BANKROLL_MIN_USDC=100
SIM_BANKROLL_MAX_USDC=1000
SIM_MAX_CONCURRENCY=4

# Local API for extension market matching (first 5 tweets)
AI_MATCH_API_PORT=8787
AI_MATCH_ALLOW_ALL_ORIGINS=true
# Set true to force parser/heuristic instead of Bedrock for this API
API_FORCE_LOCAL_MODEL=false
